{
  "name": "readerby",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Real-time system telemetry and resource usage tracking",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "server": "nodemon server.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tunnel": "lt --port 3001",
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "deploy": "npm run build && NODE_ENV=production node server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "docker:build": "docker build -t readerby .",
    "docker:run": "docker run -p 3001:3001 readerby"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@netlify/neon": "^0.1.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "framer-motion": "^12.25.0",
    "lucide-react": "^0.562.0",
    "puppeteer": "^24.34.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-use": "^17.6.0",
    "recharts": "^3.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "systeminformation": "^5.30.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "localtunnel": "^2.0.2",
    "nodemon": "^3.1.11",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0"
  }
}
